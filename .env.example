# PostgreSQL + pgvector
DATABASE_URL="postgresql://postgres:password@localhost:5433/tailorcv"

# TaylorCV auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
RESEND_API_KEY=""
AUTH_EMAIL_FROM="TaylorCV <hello@your-domain.com>"

# Abuse controls
ABUSE_HASH_SECRET=""

# Stripe billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PREMIUM_ANNUAL=""
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_CUSTOMER_PORTAL_MONTHLY_CONFIGURATION_ID=""
STRIPE_CUSTOMER_PORTAL_ANNUAL_LOCKED_CONFIGURATION_ID=""

# Mock mode lets the seeded MVP flow run without OpenAI credentials.
USE_MOCK_AI="true"

# Required when USE_MOCK_AI="false".
OPENAI_API_KEY=""
OPENAI_FAST_MODEL=""
OPENAI_STRONG_MODEL=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
