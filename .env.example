# PostgreSQL + pgvector
DATABASE_URL="postgresql://postgres:password@localhost:5433/tailorcv"

# Clerk auth. Required for sign-in, export gating, and Application Hub.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Mock mode lets the seeded MVP flow run without OpenAI credentials.
USE_MOCK_AI="true"

# Required when USE_MOCK_AI="false".
OPENAI_API_KEY=""
OPENAI_FAST_MODEL=""
OPENAI_STRONG_MODEL=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
