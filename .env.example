# Required for local development
DATABASE_URL="postgresql://postgres:password@localhost:5433/tailorcv"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters-for-local-dev"
BETTER_AUTH_URL="http://localhost:3000"
ABUSE_HASH_SECRET="replace-with-at-least-32-characters-for-local-dev"
USE_MOCK_AI="true"

# Optional local feature switches
# Keep these false unless you are actively testing the related integration.
ENABLE_EMAIL="false"
ENABLE_BILLING="false"

# Required when USE_MOCK_AI="false"
OPENAI_API_KEY=""
OPENAI_FAST_MODEL=""
OPENAI_STRONG_MODEL=""

# Required for production email, or local email testing with ENABLE_EMAIL="true"
# Placeholder values are fine while ENABLE_EMAIL="false" in local development.
RESEND_API_KEY=""
AUTH_EMAIL_FROM="TaylorCV <hello@your-domain.com>"

# Required for production billing, or local checkout/webhook testing with ENABLE_BILLING="true"
# Placeholder values are fine while ENABLE_BILLING="false" in local development.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PREMIUM_ANNUAL=""
STRIPE_PRICE_PREMIUM_MONTHLY=""

# Optional customer portal config
STRIPE_CUSTOMER_PORTAL_MONTHLY_CONFIGURATION_ID=""
STRIPE_CUSTOMER_PORTAL_ANNUAL_LOCKED_CONFIGURATION_ID=""
