{
  "name": "TailorCV",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "dev": "next dev --turbo",
    "postinstall": "prisma generate",
    "preview": "next build && next start",
    "qa:cv-screenshot": "node scripts/qa-cv-screenshot.mjs",
    "start": "next start",
    "test:acceptance": "NODE_ENV=test USE_MOCK_AI=true node scripts/test-acceptance.mjs",
    "test:layout": "NODE_ENV=test USE_MOCK_AI=true node scripts/test-layout.mjs",
    "test:retrieval": "NODE_ENV=test USE_MOCK_AI=true node scripts/test-retrieval.mjs",
    "test:memory": "NODE_ENV=test USE_MOCK_AI=true node --conditions react-server scripts/test-memory.mjs",
    "test:profiler": "NODE_ENV=test USE_MOCK_AI=true node --conditions react-server scripts/test-candidate-profiler.mjs",
    "test:gap-questions": "NODE_ENV=test USE_MOCK_AI=true node --conditions react-server scripts/test-gap-questions.mjs",
    "test:gap-selection": "NODE_ENV=test USE_MOCK_AI=true node --conditions react-server scripts/test-gap-selection.mjs",
    "test:match-snapshot": "NODE_ENV=test USE_MOCK_AI=true node scripts/test-match-snapshot.mjs",
    "test:match-framing": "NODE_ENV=test USE_MOCK_AI=true node scripts/test-deterministic-match-framing.mjs",
    "test:scoring": "NODE_ENV=test USE_MOCK_AI=true node --conditions react-server scripts/test-scoring.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
